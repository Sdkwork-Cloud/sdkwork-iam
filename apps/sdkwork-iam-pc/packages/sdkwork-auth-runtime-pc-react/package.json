{
  "name": "@sdkwork/auth-runtime-pc-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Headless auth runtime exports for non-UI consumers.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./handleSdkworkSessionAuthUnauthorizedError": {
      "types": "./src/handleSdkworkSessionAuthUnauthorizedError.ts",
      "import": "./src/handleSdkworkSessionAuthUnauthorizedError.ts",
      "default": "./src/handleSdkworkSessionAuthUnauthorizedError.ts"
    },
    "./sdkSessionAuthError": {
      "types": "./src/sdkSessionAuthError.ts",
      "import": "./src/sdkSessionAuthError.ts",
      "default": "./src/sdkSessionAuthError.ts"
    },
    "./appbasePcAuthSessionBridge": {
      "types": "./src/appbasePcAuthSessionBridge.ts",
      "import": "./src/appbasePcAuthSessionBridge.ts",
      "default": "./src/appbasePcAuthSessionBridge.ts"
    },
    "./appbasePcAuthRuntime": {
      "types": "./src/appbasePcAuthRuntime.ts",
      "import": "./src/appbasePcAuthRuntime.ts",
      "default": "./src/appbasePcAuthRuntime.ts"
    },
    "./attachSdkworkSdkSessionAuthBoundary": {
      "types": "./src/attachSdkworkSdkSessionAuthBoundary.ts",
      "import": "./src/attachSdkworkSdkSessionAuthBoundary.ts",
      "default": "./src/attachSdkworkSdkSessionAuthBoundary.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/iam-app-sdk": "workspace:*",
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/iam-credential-entry": "workspace:*",
    "@sdkwork/iam-runtime": "workspace:*",
    "@sdkwork/sdk-common": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "sdkwork": {
    "workspace": "sdkwork-iam",
    "architecture": "pc-react",
    "domain": "iam",
    "capability": "auth-runtime",
    "status": "ready"
  }
}
