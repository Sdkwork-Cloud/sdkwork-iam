{
  "name": "@sdkwork/iam-pc-core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "IAM PC dependency composition entry and reusable-module registry.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./composition": {
      "types": "./src/composition/index.ts",
      "import": "./src/composition/index.ts",
      "default": "./src/composition/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/iam-runtime": "workspace:*",
    "@sdkwork/iam-react": "workspace:*",
    "@sdkwork/auth-runtime-pc-react": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "sdkwork": {
    "architecture": "pc",
    "capability": "iam-pc-core",
    "domain": "iam",
    "packageType": "runtime",
    "status": "standard"
  }
}
