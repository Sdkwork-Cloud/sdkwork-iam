  },
  "verification": {
    "commands": [
      "pnpm run typecheck",
      "pnpm run test:iam-standard-contracts"
    ]
  },
  "contracts": {
    "publicExports": [],
    "sdkClients": [
      "@sdkwork/iam-app-sdk",
      "@sdkwork/iam-backend-sdk"
    ]
