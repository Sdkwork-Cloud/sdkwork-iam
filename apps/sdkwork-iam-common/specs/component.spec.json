{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "@sdkwork/iam-common",
    "displayName": "SDKWork IAM Common",
    "version": "0.1.0",
    "type": "typescript-package",
    "root": "sdkwork-iam/apps/sdkwork-iam-common",
    "domain": "iam",
    "capability": "iam-common",
    "languages": [
      "typescript"
    ],
    "generated": false,
    "private": true,
    "status": "standard",
    "manifests": [
      "packages/sdkwork-iam-contracts/package.json",
      "packages/sdkwork-iam-runtime/package.json",
      "packages/sdkwork-iam-service/package.json",
      "packages/sdkwork-iam-sdk-adapter/package.json",
      "packages/sdkwork-iam-credential-entry/package.json",
      "packages/sdkwork-iam-application-bootstrap/package.json"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "APPLICATION_SPEC.md",
      "path": "../../../sdkwork-specs/APPLICATION_SPEC.md",
      "purpose": "Cross-architecture shared package-family placement."
    },
    {
      "file": "APP_SDK_INTEGRATION_SPEC.md",
      "path": "../../../sdkwork-specs/APP_SDK_INTEGRATION_SPEC.md",
      "purpose": "Generated SDK wiring and IAM runtime integration."
    },
    {
      "file": "IAM_SPEC.md",
      "path": "../../../sdkwork-specs/IAM_SPEC.md",
      "purpose": "IAM domain boundary and package layering."
    }
  ],
  "integration": {
    "utils": "All common packages depend on @sdkwork/utils for trim, isBlank, coalesce, and defaultIfBlank.",
    "sdkPolicy": "Services consume generated SDK clients through sdk-adapter ports; no raw HTTP."
  },
  "contracts": {
    "publicExports": [
      "@sdkwork/iam-contracts",
      "@sdkwork/iam-runtime",
      "@sdkwork/iam-service",
      "@sdkwork/iam-sdk-adapter",
      "@sdkwork/iam-credential-entry",
      "@sdkwork/iam-application-bootstrap"
    ]
  },
  "verification": {
    "commands": [
      "pnpm run typecheck",
      "pnpm run test:iam-standard-contracts"
    ]
  }
}
