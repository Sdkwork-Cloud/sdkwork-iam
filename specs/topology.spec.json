{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-iam",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "serviceLayout": {
      "allowed": [
        "unified-process",
        "split-services"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.unified-process.development",
    "productionProfileId": "cloud.split-services.production",
    "gatewayBind": "127.0.0.1:3901"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_IAM_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_IAM_APPLICATION_PUBLIC_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "iam.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_IAM"
  },
  "components": {
    "gatewayAssembly": {
      "crate": "sdkwork-iam-gateway-assembly",
      "manifest": "crates/sdkwork-iam-gateway-assembly/assembly-manifest.json"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.unified-process.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-iam-gateway-assembly",
            "required": true
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.split-services.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-iam-gateway-assembly",
            "required": true
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      }
    }
  }
}
