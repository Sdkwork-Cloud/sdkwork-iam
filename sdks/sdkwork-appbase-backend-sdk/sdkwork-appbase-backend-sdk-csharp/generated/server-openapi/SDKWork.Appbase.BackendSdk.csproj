<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>SDKWork.Appbase.BackendSdk</RootNamespace>
    <AssemblyName>SDKWork.Appbase.BackendSdk</AssemblyName>
    <PackageId>SDKWork.Appbase.BackendSdk</PackageId>
    <Version>1.0.0</Version>
    <Authors>SDKWork Team</Authors>
    <Description>sdkwork-appbase-backend-sdk SDK</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup Condition="Exists('../../../../../../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-csharp/SDKwork.Common.csproj')">
    <ProjectReference Include="../../../../../../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-csharp/SDKwork.Common.csproj" />
  </ItemGroup>

  <ItemGroup Condition="!Exists('../../../../../../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-csharp/SDKwork.Common.csproj')">
    <PackageReference Include="SDKwork.Common" Version="1.0.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Net.Http.Json" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Tests/**/*.cs" />
    <None Include="Tests/**/*.cs" />
  </ItemGroup>

</Project>
